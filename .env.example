# ─────────────────────────────────────────────────────────────
# AI Voice Receptionist — Environment Variables
# Copy this file to `.env.local` for local dev, and set the same
# variables in the Vercel Dashboard (Project → Settings → Environment
# Variables) for production. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────

# ── Public base URL of THIS deployment (no trailing slash) ──
# Used to build absolute Twilio webhook action/callback URLs.
# Local:  https://<your-ngrok-id>.ngrok-free.app
# Prod:   https://<your-project>.vercel.app
PUBLIC_BASE_URL=https://your-project.vercel.app

# ── LLM (OpenAI-compatible) ──────────────────────────────────
# Works with OpenAI, Azure OpenAI, Groq, Together, OpenRouter,
# Ollama (http://localhost:11434/v1), vLLM, LM Studio, etc.
LLM_API_KEY=sk-your-llm-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# Max time (ms) to wait for the LLM before falling back gracefully.
LLM_TIMEOUT_MS=8000

# ── Twilio ───────────────────────────────────────────────────
# Required for webhook signature validation (security).
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Set to "false" to disable signature validation (ONLY for local testing).
TWILIO_VALIDATE_SIGNATURE=true
# Twilio speech recognition language + hint model.
TWILIO_SPEECH_LANGUAGE=en-US
# Voice used by Twilio <Say>. Amazon Polly voices: Polly.Joanna, Polly.Matthew, etc.
TWILIO_TTS_VOICE=Polly.Joanna

# ── Optional: ElevenLabs TTS ─────────────────────────────────
# If TTS_PROVIDER=elevenlabs and these are set, replies are synthesized
# with ElevenLabs and played via <Play>. Otherwise Twilio <Say> is used.
TTS_PROVIDER=twilio
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# ── Optional: Supabase (database abstraction) ────────────────
# If set, sessions/bookings can be persisted via the Supabase adapter.
# If unset, the in-memory store is used (fine for single-instance / dev).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Session / behavior tuning ────────────────────────────────
SESSION_TTL_MS=1800000
MAX_HISTORY_TURNS=12
